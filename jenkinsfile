pipeline{
    agent any
    stages{
        stage('Build') {
            steps{
                echo 'Building the project...'
                sh 'npm install -g pnpm'
                sh 'pnpm install'
                sh 'pnpm build'
            }
        }
        stage('Deploy') {
            steps{
                echo 'Deploying the project...'
                sh 'pnpm start'
            }
            
        }
    }
}